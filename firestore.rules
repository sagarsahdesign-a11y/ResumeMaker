rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data, isCreate) {
      return data.keys().hasAll(['email', 'credits', 'createdAt', 'updatedAt']) 
          && data.email is string
          && data.credits is number
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    function isValidResume(data) {
      return data.keys().hasAll(['userId', 'jobTitle', 'atsScore', 'content', 'createdAt', 'updatedAt'])
          && data.userId is string && data.userId == request.auth.uid
          && data.jobTitle is string && data.jobTitle.size() <= 500
          && data.atsScore is number
          && data.content is string && data.content.size() <= 50000
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId 
          && isValidId(userId)
          && incoming().keys().hasAll(['email', 'credits', 'createdAt', 'updatedAt'])
          && incoming().email is string && incoming().email.size() <= 200
          && incoming().credits is number
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && request.auth.uid == userId 
          && incoming().diff(existing()).affectedKeys().hasOnly(['credits', 'updatedAt'])
          && incoming().credits is number
          && incoming().updatedAt == request.time;
      allow delete: if false;
    }

    match /resumes/{resumeId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
          && isValidResume(incoming())
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && existing().userId == request.auth.uid
          && (
            incoming().diff(existing()).affectedKeys().hasOnly(['jobTitle', 'atsScore', 'content', 'updatedAt'])
          )
          && incoming().jobTitle is string && incoming().jobTitle.size() <= 500
          && incoming().atsScore is number
          && incoming().content is string && incoming().content.size() <= 50000
          && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
